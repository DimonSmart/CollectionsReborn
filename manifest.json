{
  "manifest_version": 3,
  "name": "Collections Reborn",
  "version": "0.1.4",
  "description": "A collections-style side panel for organizing browser bookmarks.",
  "minimum_chrome_version": "114",
  "permissions": [
    "bookmarks",
    "sidePanel",
    "storage",
    "favicon",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Collections Reborn",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
