{
  "name": "collections-reborn",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "preview": "vite build && echo \"Load dist/ as unpacked extension\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "vitest run",
    "verify:store-assets": "node scripts/verify-store-assets.mjs",
    "pages:build": "node scripts/build-pages.mjs",
    "package": "npm run check && npm test && npm run verify:store-assets && node scripts/package-extension.mjs",
    "package:chrome": "npm run package",
    "package:edge": "npm run package",
    "assets:store": "node scripts/create-store-assets.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/sortablejs": "^1.15.9",
    "archiver": "^7.0.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "sortablejs": "^1.15.7"
  }
}
